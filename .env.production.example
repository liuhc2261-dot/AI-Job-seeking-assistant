# Copy these values into your hosting provider's production environment settings.
# Keep secrets private unless the variable name starts with NEXT_PUBLIC_.

# Database
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<database>?schema=public"

# Auth
AUTH_SECRET="<generate-a-long-random-secret>"
AUTH_TRUST_HOST="true"
NEXT_PUBLIC_APP_URL="https://your-domain.example"

# AI
OPENAI_API_KEY="<openai-api-key>"
OPENAI_MODEL="gpt-4.1-mini"

# Monitoring
SENTRY_DSN="<server-sentry-dsn>"
NEXT_PUBLIC_SENTRY_DSN="<browser-sentry-dsn>"
SENTRY_AUTH_TOKEN="<optional-for-sourcemap-upload>"

# Analytics
NEXT_PUBLIC_POSTHOG_TOKEN="<posthog-project-api-key>"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
# Optional compatibility alias used by the app:
NEXT_PUBLIC_POSTHOG_KEY=""

# PDF export runtime
PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium"
