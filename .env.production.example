# Copy these values into your hosting provider's production environment settings.
# Keep secrets private unless the variable name starts with NEXT_PUBLIC_.

# Database
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<database>?schema=public"

# Auth
AUTH_SECRET="<generate-a-long-random-secret>"
AUTH_TRUST_HOST="true"
NEXT_PUBLIC_APP_URL="https://your-domain.example"

# AI
OPENAI_API_KEY="<openai-api-key>"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_TRIAL_MODEL="gpt-5.1"
OPENAI_PAID_MODEL="gpt-5.4"

# Monitoring
SENTRY_DSN="<server-sentry-dsn>"
NEXT_PUBLIC_SENTRY_DSN="<browser-sentry-dsn>"
SENTRY_AUTH_TOKEN="<optional-for-sourcemap-upload>"

# Analytics
NEXT_PUBLIC_POSTHOG_TOKEN="<posthog-project-api-key>"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
# Optional compatibility alias used by the app:
NEXT_PUBLIC_POSTHOG_KEY=""

# Commerce callback
COMMERCE_CALLBACK_SECRET="<shared-secret-for-payment-callbacks>"

# WeChat Pay
WECHAT_PAY_APP_ID="<wechat-app-id>"
WECHAT_PAY_MCH_ID="<wechat-merchant-id>"
WECHAT_PAY_SERIAL_NO="<wechat-merchant-certificate-serial>"
WECHAT_PAY_PRIVATE_KEY="<merchant-private-key-pem>"
WECHAT_PAY_API_V3_KEY="<32-byte-api-v3-key>"
WECHAT_PAY_PLATFORM_PUBLIC_KEY="<wechat-pay-platform-public-key-pem>"
WECHAT_PAY_NOTIFY_PATH="/api/payments/wechat/notify"

# Alipay
ALIPAY_APP_ID="<alipay-app-id>"
ALIPAY_PRIVATE_KEY="<alipay-application-private-key-pem>"
ALIPAY_PUBLIC_KEY="<alipay-platform-public-key-pem>"
ALIPAY_GATEWAY_URL="https://openapi.alipay.com/gateway.do"
ALIPAY_NOTIFY_PATH="/api/payments/alipay/notify"

# PDF export runtime
PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium"

# PDF export storage
# Use "s3" for AWS S3, or "r2" for Cloudflare R2 via the S3-compatible API.
EXPORT_STORAGE_DRIVER="r2"
EXPORT_STORAGE_BUCKET="<bucket-name>"
EXPORT_STORAGE_REGION="auto"
EXPORT_STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
EXPORT_STORAGE_ACCESS_KEY_ID="<object-storage-access-key-id>"
EXPORT_STORAGE_SECRET_ACCESS_KEY="<object-storage-secret-access-key>"
EXPORT_STORAGE_PREFIX="resume-exports"
EXPORT_STORAGE_FORCE_PATH_STYLE="false"
