# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_job_assistant?schema=public"

# Auth
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_TRUST_HOST="true"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_TRIAL_MODEL="gpt-5.1"
OPENAI_PAID_MODEL="gpt-5.4"

# Monitoring
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_TOKEN=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Commerce callback
COMMERCE_CALLBACK_SECRET=""

# PDF export runtime
PUPPETEER_EXECUTABLE_PATH=""

# PDF export storage
# Use local disk in development. Switch to s3 or r2 in production containers.
EXPORT_STORAGE_DRIVER="local"
EXPORT_STORAGE_BUCKET=""
EXPORT_STORAGE_REGION=""
EXPORT_STORAGE_ENDPOINT=""
EXPORT_STORAGE_ACCESS_KEY_ID=""
EXPORT_STORAGE_SECRET_ACCESS_KEY=""
EXPORT_STORAGE_PREFIX="resume-exports"
EXPORT_STORAGE_FORCE_PATH_STYLE="false"
